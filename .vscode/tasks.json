{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "gradle: assembleDebug",
            "type": "shell",
            "command": "./gradlew assembleDebug",
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "installDebug",
