        },
        {
            "label": "runApp",
            "type": "shell",
            "command": "adb shell am start -n com.example.migrainecollector/.MainActivity",
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        }
    ]
}